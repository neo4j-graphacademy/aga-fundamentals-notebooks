# Aura API credentials — used by GdsSessions to manage AGA sessions.
# Generate these in the Aura Console under Account -> API credentials.
AURA_CLIENT_ID=""
AURA_CLIENT_SECRET=""

# Only needed if your Aura account belongs to more than one project.
# Leave blank for single-project accounts — the Python client auto-detects.
# Find the ID on your project page in the Aura Console.
AURA_PROJECT_ID=""

# AuraDB instance details — used by attached sessions to project from.
# Find these in the Aura Console for the AuraDB instance you want to use.
AURA_URI=""
AURA_USERNAME=""
AURA_PASSWORD=""
