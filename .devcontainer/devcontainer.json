{
  "name": "Aura Graph Analytics Fundamentals",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.14-bookworm",
  "postCreateCommand": "bash .devcontainer/setup.sh && bash .devcontainer/start-jupyter.sh",
  "postStartCommand": "bash .devcontainer/start-jupyter.sh",
  "postAttachCommand": "bash .devcontainer/start-jupyter.sh && echo '' && echo 'Codespace ready. Jupyter running on port 8888.' && echo ''",
  "forwardPorts": [8888],
  "portsAttributes": {
    "8888": {
      "label": "Jupyter Server",
      "visibility": "private",
      "onAutoForward": "ignore"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true,
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "files.exclude": {
          "**/__pycache__": true,
          "**/.ipynb_checkpoints": true
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags"
      ]
    }
  }
}
